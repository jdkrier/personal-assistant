# Copy this to .env and fill in your values.
# Never commit .env to git.

CANVAS_ICAL_URL=https://canvas.asu.edu/feeds/calendars/user_XXXX.ics
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_CREDENTIALS_PATH=/data/credentials.json
GROUPME_ACCESS_TOKEN=your_groupme_token
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Auth — login page
APP_PASSWORD=choose_a_strong_password
SESSION_SECRET=run_python3_-c_"import_secrets;print(secrets.token_hex(32))"_to_generate
